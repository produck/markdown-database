{
	"name": "@produck/cellulose-workspace",
	"private": true,
	"scripts": {
		"deps:install": "npm -v && npm install",
		"deps:ci-install": "npm install --include=optional",
		"lint": "eslint --fix",
		"test": "npm run --workspaces build:version --if-present && npm test --workspaces --if-present",
		"coverage": "c8 npm run test",
		"publish": "npm run lint && npm run test && lerna publish --no-private"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@produck/eslint-rules": "^0.2.7",
		"@types/node": "^25.4.0",
		"c8": "^11.0.0",
		"eslint": "^10.0.3",
		"globals": "^17.4.0",
		"lerna": "^9.0.5",
		"typescript-eslint": "^8.57.0"
	},
	"workspaces": [
		"packages/cellulose/node",
		"packages/cellulose/transcriber",
		"packages/cellulose/provider",
		"packages/provider/fs-directory",
		"packages/node/string-json",
		"packages/node/string-json-schema",
		"packages/linen/storage"
	]
}
